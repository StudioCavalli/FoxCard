# Database
# For MongoDB Atlas, use this format with TLS enabled
# IMPORTANT: Remove tlsAllowInvalidCertificates in production if you have valid certificates
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&tls=true&tlsAllowInvalidCertificates=true"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cloudflare R2 (Image Storage)
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="https://your-custom-domain.com" # Or use R2.dev URL

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
