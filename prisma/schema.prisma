// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Multi-tenancy: Each store is isolated
model Store {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  logo        String?
  domain      String?  @unique

  // Owner info
  ownerId     String   @db.ObjectId
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Store settings
  settings    Json?    // Flexible settings object
  theme       Json?    // Theme customization

  // Relations
  products    Product[]
  categories  Category[]
  orders      Order[]
  customers   Customer[]
  discountCodes DiscountCode[]
  shippingZones ShippingZone[]
  webhooks    Webhook[]
  apiKeys     ApiKey[]
  envVariables EnvVariable[] @relation("StoreEnvVariables")
  emailTemplates EmailTemplate[]
  emailLogs   EmailLog[]
  newsletterSubscribers NewsletterSubscriber[]
  invoices    Invoice[]
  roles       Role[]
  storeUsers  StoreUser[]
  auditLogs   AuditLog[]
  themes      Theme[]
  plugins     Plugin[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String    // Hashed password
  role          UserRole  @default(USER)

  stores        Store[]
  accounts      Account[]
  sessions      Session[]
  storeUsers    StoreUser[]
  auditLogs     AuditLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?
  price       Float
  compareAtPrice Float?
  cost        Float?

  // Product type
  type        ProductType @default(SIMPLE)

  // Inventory
  sku         String?
  barcode     String?
  trackInventory Boolean @default(true)
  quantity    Int      @default(0)
  lowStockThreshold Int?

  // Images
  images      String[] // Array of image URLs
  thumbnail   String?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Status
  status      ProductStatus @default(DRAFT)
  featured    Boolean @default(false)

  // Relations
  categoryId  String?  @db.ObjectId
  category    Category? @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([categoryId])
  @@index([status])
}

model ProductVariant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name        String
  sku         String?
  price       Float?
  quantity    Int      @default(0)
  image       String?

  // Variant options (e.g., color: "red", size: "L")
  options     Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?
  image       String?

  // Hierarchy
  parentId    String?  @db.ObjectId
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Category[] @relation("CategoryHierarchy")

  products    Product[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([parentId])
}

model Customer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  email       String
  firstName   String?
  lastName    String?
  phone       String?

  // Address
  address     Json?

  orders      Order[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, email])
  @@index([storeId])
}

model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  storeId         String      @db.ObjectId
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  orderNumber     String      @unique

  customerId      String?     @db.ObjectId
  customer        Customer?   @relation(fields: [customerId], references: [id])

  // Customer info (for guest checkout)
  customerEmail   String
  customerName    String?

  // Pricing
  subtotal        Float
  tax             Float       @default(0)
  shipping        Float       @default(0)
  discount        Float       @default(0)
  total           Float

  // Status
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)

  // Payment
  paymentMethod   String?
  paymentIntentId String?

  // Shipping
  shippingAddress Json?
  billingAddress  Json?

  // Items
  items           OrderItem[]

  // Invoice
  invoice         Invoice?

  // Notes
  notes           String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([storeId])
  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @db.ObjectId
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id])

  name        String   // Snapshot of product name
  price       Float    // Snapshot of price at time of order
  quantity    Int

  // Variant info
  variantId   String?
  variantName String?

  total       Float

  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ProductType {
  SIMPLE
  VARIABLE
  DIGITAL
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
  RETURNED
}

model DiscountCode {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId         String   @db.ObjectId
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  code            String
  description     String?

  // Discount type
  type            DiscountType
  value           Float    // Percentage (0-100) or fixed amount

  // Usage limits
  usageLimit      Int?     // Max number of uses
  usageCount      Int      @default(0)
  minOrderAmount  Float?   // Minimum order amount to apply

  // Validity
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([storeId, code])
  @@index([storeId])
}

model ShippingZone {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  countries   String[] // Array of country codes (FR, BE, etc.)

  // Shipping rates
  rates       ShippingRate[]

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
}

model ShippingRate {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  shippingZoneId  String   @db.ObjectId
  shippingZone    ShippingZone @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade)

  name            String
  price           Float
  minOrderAmount  Float?   // Free shipping threshold
  estimatedDays   String?  // "3-5 days"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shippingZoneId])
}

model Webhook {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  url         String
  events      String[] // Array of webhook event types
  secret      String   // Secret for HMAC signature
  enabled     Boolean  @default(true)

  // Custom headers
  headers     Json?    // Custom headers to send with webhook

  // Deliveries
  deliveries  WebhookDelivery[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
}

model WebhookDelivery {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  webhookId   String   @db.ObjectId
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  event       String   // Webhook event type
  payload     Json     // Full webhook payload

  status      WebhookDeliveryStatus @default(PENDING)
  attempts    Int      @default(0)

  // Response info
  statusCode  Int?
  response    String?
  error       String?

  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
}

model ApiKey {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String   // Descriptive name for the API key
  key         String   @unique // The actual API key (hashed)
  prefix      String   // First 8 characters for identification

  // Permissions
  scopes      String[] // Array of permission scopes (e.g., "products:read", "orders:write")

  // Rate limiting
  rateLimit   Int      @default(1000) // Requests per hour

  // Status
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
  @@index([isActive])
}

model EnvVariable {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade, name: "StoreEnvVariables")

  key         String   // Variable name (e.g., "STRIPE_SECRET_KEY")
  value       String   // Encrypted value
  category    EnvCategory
  isSecret    Boolean  @default(false) // If true, value is encrypted
  description String?  // Optional description

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, key])
  @@index([storeId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum EnvCategory {
  DATABASE
  SMTP
  STRIPE
  R2
  AUTH
  GENERAL
}

// Email System
model EmailTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String   // Template name (e.g., "order_confirmation")
  subject     String   // Email subject with variable support
  htmlBody    String   // HTML content with variable support
  textBody    String?  // Plain text fallback
  designJson  Json?    // WYSIWYG editor design (Unlayer JSON)

  // Template metadata
  description String?
  variables   String[] // List of available variables (e.g., ["orderNumber", "customerName"])

  // Status
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false) // System default templates

  // Usage tracking
  logs        EmailLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, name])
  @@index([storeId])
  @@index([isActive])
}

model EmailLog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId         String   @db.ObjectId
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // Template info
  templateId      String?  @db.ObjectId
  template        EmailTemplate? @relation(fields: [templateId], references: [id])
  templateName    String   // Snapshot of template name

  // Email details
  to              String
  from            String
  subject         String
  htmlBody        String
  textBody        String?

  // Tracking
  status          EmailStatus @default(PENDING)
  attempts        Int      @default(0)
  error           String?

  // Open tracking
  opened          Boolean  @default(false)
  openedAt        DateTime?
  openCount       Int      @default(0)

  // Click tracking
  clicked         Boolean  @default(false)
  clickedAt       DateTime?
  clickCount      Int      @default(0)

  // Related entities
  orderId         String?  @db.ObjectId
  customerId      String?  @db.ObjectId

  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([templateId])
  @@index([status])
  @@index([to])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  email       String
  firstName   String?
  lastName    String?

  // Subscription status
  status      SubscriberStatus @default(PENDING)
  confirmedAt DateTime?

  // Opt-in tracking
  source      String?  // Where they subscribed from
  ipAddress   String?
  userAgent   String?

  // Preferences
  tags        String[] // Segmentation tags
  preferences Json?    // Email preferences

  // Unsubscribe
  unsubscribedAt DateTime?
  unsubscribeReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, email])
  @@index([storeId])
  @@index([status])
  @@index([email])
}

enum EmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
  BOUNCED
}

enum SubscriberStatus {
  PENDING      // Awaiting confirmation
  CONFIRMED    // Confirmed via double opt-in
  UNSUBSCRIBED // Unsubscribed
}

model Invoice {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId         String   @db.ObjectId
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  orderId         String   @unique @db.ObjectId
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Invoice details
  invoiceNumber   String   @unique // Sequential number (e.g., INV-2025-0001)
  invoiceDate     DateTime @default(now())
  dueDate         DateTime?

  // Customer info (snapshot)
  customerName    String
  customerEmail   String
  customerAddress Json?

  // Merchant info (snapshot)
  merchantName    String
  merchantAddress Json?
  merchantTax     String?  // Tax ID / SIRET / VAT number

  // Line items (snapshot from order)
  items           Json     // Array of invoice items

  // Amounts
  subtotal        Float
  tax             Float
  shipping        Float
  discount        Float
  total           Float

  // Payment
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?

  // PDF
  pdfUrl          String?  // URL to R2/S3
  pdfGenerated    Boolean  @default(false)
  pdfGeneratedAt  DateTime?

  // Notes
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([invoiceDate])
}

// RBAC System (Role-Based Access Control)
model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String   // Role name (e.g., "Manager", "Staff")
  description String?

  // Permissions (array of permission keys)
  permissions String[] // e.g., ["products.create", "products.update", "orders.view"]

  // System roles cannot be deleted or modified
  isSystem    Boolean  @default(false)

  // Users with this role
  users       StoreUser[]

  // Audit
  auditLogs   AuditLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, name])
  @@index([storeId])
}

// Association between User and Store with a Role
model StoreUser {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeId   String   @db.ObjectId
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  roleId    String   @db.ObjectId
  role      Role     @relation(fields: [roleId], references: [id])

  // Invitation tracking
  invitedBy String?  @db.ObjectId
  invitedAt DateTime @default(now())
  acceptedAt DateTime?

  // Status
  status    StoreUserStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, storeId])
  @@index([storeId])
  @@index([userId])
  @@index([roleId])
}

enum StoreUserStatus {
  PENDING   // Invitation sent, not yet accepted
  ACTIVE    // Active user in the store
  SUSPENDED // Temporarily suspended
  REMOVED   // Removed from store
}

// Audit log for tracking administrative actions
model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // Who performed the action
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  // Action details
  action      String   // e.g., "product.create", "order.update", "user.delete"
  entity      String   // e.g., "Product", "Order", "User"
  entityId    String?  // ID of the affected entity

  // Role at the time of action
  roleId      String?  @db.ObjectId
  role        Role?    @relation(fields: [roleId], references: [id])

  // Metadata
  metadata    Json?    // Additional context (before/after values, etc.)
  ipAddress   String?
  userAgent   String?

  // Result
  success     Boolean  @default(true)
  errorMessage String?

  createdAt   DateTime @default(now())

  @@index([storeId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Theme System
model Theme {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  description String?
  version     String   @default("1.0.0")

  // Theme configuration (colors, fonts, spacing, etc.)
  config      Json     // { colors: {...}, fonts: {...}, spacing: {...} }

  // Status
  isActive    Boolean  @default(false)
  isSystem    Boolean  @default(false) // System themes (Minimal, Luxe, Tech)

  // Components
  components  ThemeComponent[]

  // Source (if installed from marketplace)
  sourcePresetId String?  @db.ObjectId
  sourcePreset   ThemePreset? @relation(fields: [sourcePresetId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
  @@index([isActive])
  @@index([sourcePresetId])
}

model ThemeComponent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  themeId     String   @db.ObjectId
  theme       Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  // Component details
  name        String   // e.g., "Header", "Footer", "Product Card"
  type        String   // Component type (header, footer, hero, product-grid, etc.)

  // Visual editor data (GrapesJS or similar)
  html        String?  // Generated HTML
  css         String?  // Generated CSS
  designJson  Json?    // Editor's JSON structure

  // Configuration
  props       Json?    // Component-specific props

  // Order
  order       Int      @default(0)
  isEnabled   Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([themeId])
  @@index([type])
}

model ThemePreset {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  name        String   @unique
  slug        String   @unique
  description String?

  // Preview
  thumbnail   String?
  screenshots String[] // Array of screenshot URLs

  // Theme data (base template)
  config      Json     // Default colors, fonts, etc.
  components  Json     // Default components

  // Metadata
  author      String?
  version     String   @default("1.0.0")
  tags        String[] // ["minimal", "modern", "ecommerce"]

  // Marketplace
  isPublic    Boolean  @default(false)
  isPremium   Boolean  @default(false)
  price       Float?

  // Stats
  installCount Int     @default(0)
  rating      Float?
  reviewCount Int      @default(0)

  // Installations
  installations Theme[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublic])
}

// ============================================
// PLUGIN SYSTEM
// ============================================

// Plugin registry (marketplace presets)
model PluginPreset {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  name        String   @unique
  slug        String   @unique
  description String?

  // Plugin metadata
  type        PluginType
  category    String   // "payment", "shipping", "marketing", "seo", "analytics"
  icon        String?  // Icon URL or emoji
  thumbnail   String?
  screenshots String[]

  // Plugin code/config
  version     String   @default("1.0.0")
  config      Json     // Default configuration schema
  hooks       String[] // Events the plugin listens to
  permissions String[] // Required permissions

  // Author info
  author      String?
  authorUrl   String?
  documentation String?
  repository  String?

  // Marketplace
  isPublic    Boolean  @default(false)
  isPremium   Boolean  @default(false)
  price       Float?
  tags        String[]

  // Stats
  installCount Int     @default(0)
  rating      Float    @default(0)
  reviewCount Int      @default(0)

  // Requirements
  minVersion  String?  // Minimum FoxCard version
  dependencies String[] // Other required plugins

  // Installations
  installations Plugin[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublic])
  @@index([type])
  @@index([category])
}

// Installed plugin instance for a store
model Plugin {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  storeId     String   @db.ObjectId
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // Source preset (if from marketplace)
  presetId    String?  @db.ObjectId
  preset      PluginPreset? @relation(fields: [presetId], references: [id])

  name        String
  slug        String
  description String?
  type        PluginType
  category    String
  icon        String?
  version     String   @default("1.0.0")

  // Configuration (store-specific overrides)
  config      Json     // Plugin settings

  // State
  isEnabled   Boolean  @default(true)
  isInstalled Boolean  @default(true)

  // Timestamps
  installedAt DateTime @default(now())
  enabledAt   DateTime?
  disabledAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([type])
  @@index([isEnabled])
}

enum PluginType {
  PAYMENT
  SHIPPING
  MARKETING
  SEO
  ANALYTICS
  INTEGRATION
  UTILITY
}
