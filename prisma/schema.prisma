// Loyalty Program - VIP Tiers
enum LoyaltyTier {
  BRONZE  // 0-999€ lifetime spend
  SILVER  // 1000-4999€ lifetime spend
  GOLD    // 5000€+ lifetime spend
}

enum LoyaltyTransactionType {
  EARN          // Points earned (purchase, signup bonus, referral)
  REDEEM        // Points used for discount
  EXPIRE        // Points expired (12 months)
  ADMIN_ADJUST  // Manual adjustment by admin
}

// Loyalty Transactions - History of all points movements
model LoyaltyTransaction {
  id         String                  @id @default(auto()) @map("_id") @db.ObjectId
  customerId String                  @db.ObjectId
  customer   Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  storeId    String                  @db.ObjectId

  type       LoyaltyTransactionType
  points     Int                     // Positive for earn, negative for redeem/expire

  // Context
  orderId    String?                 @db.ObjectId  // Related order if EARN or REDEEM
  description String                                // "Purchase #ORD-123", "Signup bonus", "Points expired"

  // Expiration tracking (for EARN transactions)
  expiresAt  DateTime?                              // Points expire 12 months after earning
  isExpired  Boolean                 @default(false)

